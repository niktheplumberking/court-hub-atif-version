NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
ANTHROPIC_API_KEY=sk-ant-placeholder
# Comma-separated admin email allow-list. Only these accounts may access /admin,
# run the product/order actions, and use the Instagram importer. MUST match the
# email of the admin auth account whose id is inserted into the `admins` table
# (supabase/schema.sql). Fail-closed: if unset, nobody is treated as an admin.
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3005
# WhatsApp business number for lead-gen links (no + or spaces). Placeholder until client provides the real number.
NEXT_PUBLIC_WHATSAPP_NUMBER=971000000000
